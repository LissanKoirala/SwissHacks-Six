# Advisory Workbench — environment template. Copy to .env and fill in.
# Everything runs offline on seed data WITHOUT these keys; they only enable live feeds + LLM prose.

# Phoeniqs — LLM + embeddings (the only LLM cost surface). Leave blank to use deterministic drafts.
PHOENIQS_API_KEY=
PHOENIQS_API_URL=https://maas.phoeniqs.com/v1
PHOENIQS_MODEL=inference-gpt-oss-120b

# SIX Financial Data — MCP (live prices/valuation). Leave blank to use workbook seed values.
SIX_MCP_TOKEN=
SIX_MCP_URL=https://ca-mcpwebapi-tools.nicepebble-599ed11f.westeurope.azurecontainerapps.io/mcp

# Event Registry / NewsAPI.ai — live news + sentiment. Leave blank to use seed news fixtures.
NEWSAPI_KEY=
NEWSAI_API_URL=https://eventregistry.org/api/v1

# ElevenLabs — speech-to-text for RM dictation. Leave blank to fall back to in-browser Web Speech (Chrome/Edge only).
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL=scribe_v1
# STT provider: elevenlabs | phoeniqs (phoeniqs swap pending; see backend/workbench/agents/transcribe.py)
STT_PROVIDER=elevenlabs

# OCR (handwritten/printed notes) — Phoeniqs hosts a purpose-built OCR model.
# Provider: phoeniqs (only option wired). Model: inference-deepseek-ocr by default.
OCR_PROVIDER=phoeniqs
PHOENIQS_OCR_MODEL=inference-deepseek-ocr

# Master switch: set to 1 to allow live LLM/feeds when keys are present; 0 forces fully offline/deterministic.
USE_LIVE=0
