# Advisory Workbench — environment template. Copy to .env and fill in.
# Everything runs offline on seed data WITHOUT these keys; they only enable live feeds + LLM prose.

# Phoeniqs — LLM + embeddings (the only LLM cost surface). Leave blank to use deterministic drafts.
PHOENIQS_API_KEY=
PHOENIQS_API_URL=https://maas.phoeniqs.com/v1
PHOENIQS_MODEL=inference-gpt-oss-120b

# SIX Financial Data — MCP (live prices/valuation). Leave blank to use workbook seed values.
SIX_MCP_TOKEN=
SIX_MCP_URL=https://ca-mcpwebapi-tools.nicepebble-599ed11f.westeurope.azurecontainerapps.io/mcp

# Event Registry / NewsAPI.ai — live news + sentiment. Leave blank to use seed news fixtures.
NEWSAPI_KEY=
NEWSAI_API_URL=https://eventregistry.org/api/v1

# ElevenLabs — speech-to-text for RM dictation. Leave blank to fall back to in-browser Web Speech (Chrome/Edge only).
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL=scribe_v1
# STT provider: elevenlabs | phoeniqs (phoeniqs swap pending; see backend/workbench/agents/transcribe.py)
STT_PROVIDER=elevenlabs

# ElevenLabs — text-to-speech for the conversational capture voice (reuses ELEVENLABS_API_KEY).
# Leave the key blank to fall back to the browser's built-in speechSynthesis voice.
TTS_PROVIDER=elevenlabs
ELEVENLABS_TTS_MODEL=eleven_turbo_v2_5
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# OCR (handwritten/printed notes) — Phoeniqs hosts a purpose-built OCR model.
# Provider: phoeniqs (only option wired). Model: inference-deepseek-ocr by default.
OCR_PROVIDER=phoeniqs
PHOENIQS_OCR_MODEL=inference-deepseek-ocr

# --- Additional free data sources (all optional; everything falls back to seed fixtures) ---

# SEC EDGAR — corporate filings (8-K material events, full-text search, Form 4 insider trades).
# FREE, no API key; SEC's fair-access policy just asks for a User-Agent identifying you.
SEC_USER_AGENT=Advisory Workbench (contact: your_name@example.com)

# Financial Modeling Prep (free tier) — ESG controversy ratings, earnings, analyst ratings/price
# targets, fundamentals + dividends. One free key at financialmodelingprep.com powers all four.
FMP_API_KEY=

# Macro/FX digest — Frankfurter (ECB rates) needs NO key. FRED key is optional extra enrichment.
FRED_API_KEY=

# Master switch: set to 1 to allow live LLM/feeds when keys are present; 0 forces fully offline/deterministic.
USE_LIVE=0

# --- Auth (Google sign-in, identity only) + sessions + persistence ---
# Create an OAuth client (Web) in Google Cloud → APIs & Services → Credentials. In "Testing"
# publishing mode add yourself as a test user. Scopes are identity-only (openid email profile),
# which are NON-sensitive → no app verification needed. Register the redirect URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
# Scopes. Default adds Gmail (read + draft) + Calendar (read + add) — sensitive/restricted,
# fine in Testing mode for added test users (consent shows an "unverified app" warning).
# Enable the Gmail API + Google Calendar API in your project's APIs & Services → Library.
# To go back to identity-only sign-in: GOOGLE_SCOPES="openid email profile"
GOOGLE_SCOPES=openid email profile https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/gmail.compose https://www.googleapis.com/auth/calendar.events
# Fernet key encrypting stored Google tokens at rest. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENC_KEY=
# Per-client Workspace (read a client's emails/meetings, draft to them). To live-test with ONE
# real Gmail, set this to that account; each client becomes a +tag of it (you+schneider@gmail.com,
# you+huber@…) that all lands in the one inbox. Per-client override: CLIENT_EMAIL_<ID> (e.g.
# CLIENT_EMAIL_SCHNEIDER=…). Unset → the .example addresses on file in persona_seeds.json.
WORKSPACE_TEST_BASE=
# After sign-in the backend redirects the browser back here.
FRONTEND_URL=http://localhost:3000
# PROD only: extra browser origins allowed to call the API with the session cookie
# (comma-separated, exact scheme+host, no trailing slash). Localhost is always allowed.
# e.g. CORS_ORIGINS=https://billionaire.lissan.dev
CORS_ORIGINS=
# Signs the session cookie (holds only the user id). Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
SESSION_SECRET=
# Set to 1 behind HTTPS (prod) so the session cookie is marked Secure.
SESSION_HTTPS_ONLY=0
# SQLite store for RM accounts + briefing log (git-ignored).
DATABASE_URL=sqlite:///./data/workbench.db

# --- Twilio SMS morning briefing ---
# twilio.com → Console. Trial accounts can only text VERIFIED numbers until upgraded.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Briefing prose backend: deterministic (default, offline) | phoeniqs | ollama (future).
BRIEFING_COMPOSER=deterministic
# Timezone for the daily send + "today".
BRIEFING_TZ=Europe/Zurich
# Set 0 to disable the in-process scheduler (e.g. when running multiple workers).
SCHEDULER_ENABLED=1

# Google Flights live fares via the ``flights`` (fli) Python library — no API key.
# First rendezvous load can take 30–60s while routes are fetched; results are cached locally.
USE_LIVE_FLIGHTS=0

# --- The Front Door: inbound email ingestion -------------------------------------------------
# Default (fixture) runs the whole triage→task→draft pipeline on seed mail with NO credentials.
# To pull a real mailbox: set EMAIL_PROVIDER=imap, fill the IMAP_* vars, and set USE_LIVE=1.
# Works with any IMAP mailbox (Gmail app-password, Outlook, Fastmail, …).
#
# DEMO TIP — imitate a live mailbox locally with NO real account using GreenMail:
#   docker compose -f docker-compose.mail.yml up -d
#   then set: USE_LIVE=1, EMAIL_PROVIDER=imap, and the GreenMail values below
#   (EMAIL_IMAP_HOST=localhost EMAIL_IMAP_PORT=3143 EMAIL_IMAP_SSL=0, any user/password),
#   and send mail in with:  python backend/scripts/send_test_email.py
# Provider: fixture (offline) | imap (any mailbox, app password) | gmail (proper Google OAuth)
EMAIL_PROVIDER=fixture
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=
EMAIL_IMAP_PASSWORD=
EMAIL_IMAP_FOLDER=INBOX
EMAIL_IMAP_SSL=1
EMAIL_SCAN_LIMIT=25

# --- Gmail via OAuth (EMAIL_PROVIDER=gmail) — no app password, proper Google auth ------------
# Setup (a teammate does this once, after merge):
#   1. Google Cloud Console → enable Gmail API → create OAuth client (type "Desktop app") →
#      download the client secret JSON to backend/.gmail_client_secret.json
#   2. cd backend && python -m workbench.ingestion.gmail_oauth   (browser sign-in, read-only)
#   3. set EMAIL_PROVIDER=gmail and USE_LIVE=1 below — done.
# The helper writes a token file (path below). The env vars are an alternative to the token file;
# leave them blank to use the token file. NEVER commit real values (these files are git-ignored).
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=
GMAIL_TOKEN_FILE=
GMAIL_QUERY=subject:[workbench] is:unread

# --- INSTANT push (optional) — Gmail watch → Pub/Sub → POST /gmail/push ----------------------
# Set these to make ingestion real-time instead of polled. Needs the backend reachable at a public
# HTTPS URL and a Pub/Sub topic. Full walkthrough in docs/DEPLOY.md. Leave blank → poller is used.
GMAIL_PUBSUB_TOPIC=          # projects/<your-project>/topics/<your-topic>
GMAIL_WATCH_LABELS=INBOX     # comma-separated Gmail label IDs to watch
GMAIL_SUBJECT_FILTER=[workbench]   # only ingest pushed mail whose subject contains this ("" = all)
GMAIL_PUSH_TOKEN=            # random secret; the push subscription URL is …/gmail/push?token=THIS

# Autonomous Front Door poller: re-scan inbox + news/risk watch on an interval so new mail and
# material world events open tasks on their own. ON by default; set to 0 to disable.
# Advisory only — the loop creates + drafts tasks; the RM sign-off gate is untouched.
FRONT_DOOR_POLL=1
FRONT_DOOR_POLL_SECONDS=60
