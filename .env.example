# Advisory Workbench — environment template. Copy to .env and fill in.
# Everything runs offline on seed data WITHOUT these keys; they only enable live feeds + LLM prose.

# Phoeniqs — LLM + embeddings (the only LLM cost surface). Leave blank to use deterministic drafts.
PHOENIQS_API_KEY=
PHOENIQS_API_URL=https://maas.phoeniqs.com/v1
PHOENIQS_MODEL=inference-gpt-oss-120b

# SIX Financial Data — MCP (live prices/valuation). Leave blank to use workbook seed values.
SIX_MCP_TOKEN=
SIX_MCP_URL=https://ca-mcpwebapi-tools.nicepebble-599ed11f.westeurope.azurecontainerapps.io/mcp

# Event Registry / NewsAPI.ai — live news + sentiment. Leave blank to use seed news fixtures.
NEWSAPI_KEY=
NEWSAI_API_URL=https://eventregistry.org/api/v1

# ElevenLabs — speech-to-text for RM dictation. Leave blank to fall back to in-browser Web Speech (Chrome/Edge only).
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL=scribe_v1
# STT provider: elevenlabs | phoeniqs (phoeniqs swap pending; see backend/workbench/agents/transcribe.py)
STT_PROVIDER=elevenlabs

# OCR (handwritten/printed notes) — Phoeniqs hosts a purpose-built OCR model.
# Provider: phoeniqs (only option wired). Model: inference-deepseek-ocr by default.
OCR_PROVIDER=phoeniqs
PHOENIQS_OCR_MODEL=inference-deepseek-ocr

# --- Additional free data sources (all optional; everything falls back to seed fixtures) ---

# SEC EDGAR — corporate filings (8-K material events, full-text search, Form 4 insider trades).
# FREE, no API key; SEC's fair-access policy just asks for a User-Agent identifying you.
SEC_USER_AGENT=Advisory Workbench (contact: your_name@example.com)

# Financial Modeling Prep (free tier) — ESG controversy ratings, earnings, analyst ratings/price
# targets, fundamentals + dividends. One free key at financialmodelingprep.com powers all four.
FMP_API_KEY=

# Macro/FX digest — Frankfurter (ECB rates) needs NO key. FRED key is optional extra enrichment.
FRED_API_KEY=

# Master switch: set to 1 to allow live LLM/feeds when keys are present; 0 forces fully offline/deterministic.
USE_LIVE=0

# --- Auth (Google sign-in, identity only) + sessions + persistence ---
# Create an OAuth client (Web) in Google Cloud → APIs & Services → Credentials. In "Testing"
# publishing mode add yourself as a test user. Scopes are identity-only (openid email profile),
# which are NON-sensitive → no app verification needed. Register the redirect URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
# After sign-in the backend redirects the browser back here.
FRONTEND_URL=http://localhost:3000
# Signs the session cookie (holds only the user id). Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
SESSION_SECRET=
# Set to 1 behind HTTPS (prod) so the session cookie is marked Secure.
SESSION_HTTPS_ONLY=0
# SQLite store for RM accounts + briefing log (git-ignored).
DATABASE_URL=sqlite:///./data/workbench.db

# --- Twilio SMS morning briefing ---
# twilio.com → Console. Trial accounts can only text VERIFIED numbers until upgraded.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Briefing prose backend: deterministic (default, offline) | phoeniqs | ollama (future).
BRIEFING_COMPOSER=deterministic
# Timezone for the daily send + "today".
BRIEFING_TZ=Europe/Zurich
# Set 0 to disable the in-process scheduler (e.g. when running multiple workers).
SCHEDULER_ENABLED=1
